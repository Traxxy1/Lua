--!nocheck
--[[
    Universal ESP Library v1.0

    Stealth-conscious ESP library supporting players and arbitrary instances.
    Uses Drawing API + Highlight instances (parented via gethui).

    ============== API ==============
    ESP:Init()                              -- Initialize the library (call once)
    ESP:Toggle(boolean)                     -- Enable/disable globally
    ESP:Configure(settingsTable)            -- Override default settings
    ESP:Destroy()                           -- Cleanup everything

    ESP:AddPlayer(player, options)          -- Track a player
    ESP:AddObject(instance, options)        -- Track any Model/BasePart
    ESP:Remove(target)                      -- Remove tracking for player or instance

    ESP:RegisterCategory(name, definition)  -- Register a reusable category (e.g. "Wanted")
    ESP:AddPlayersByCategory(name)          -- Apply category to all current/future players

    ============== OPTIONS ==============
    {
        Name        = "Custom Label" or function(target) return string end,
        Color       = Color3 or function(target) return Color3 end,
        Filter      = function(target) return boolean end, -- show ESP only if true
        Box         = true/false,
        NameTag     = true/false,
        Health      = true/false,
        Distance    = true/false,
        Tracer      = true/false,
        Highlight   = true/false,
        MaxDistance = number,
    }
]]

local ESP = {}
ESP.__index = ESP

-- ============== SERVICES ==============
local Players      = game:GetService("Players")
local RunService   = game:GetService("RunService")
local Workspace    = game:GetService("Workspace")
local UserInputSvc = game:GetService("UserInputService")

local LocalPlayer = Players.LocalPlayer
local Camera      = Workspace.CurrentCamera

-- ============== INTERNAL STATE ==============
ESP._Tracked     = {}     -- [target] = trackedData
ESP._Categories  = {}     -- [name]   = definition
ESP._CategoryAll = {}     -- [name]   = true  (auto-apply to all players)
ESP._Connections = {}
ESP._Initialized = false
ESP._RenderConn  = nil

-- ============== DEFAULT SETTINGS ==============
ESP.Settings = {
    Enabled        = true,
    MaxDistance    = 2000,
    TeamCheck      = false,
    WallCheck      = false,
    HideOwnPlayer  = true,

    Box = {
        Color           = Color3.fromRGB(255, 255, 255),
        Thickness       = 1,
        Transparency    = 1,
        Filled          = false,
        FillTransparency= 0.7,
        Outline         = true,
        OutlineColor    = Color3.fromRGB(0, 0, 0),
    },
    Name = {
        Color           = Color3.fromRGB(255, 255, 255),
        Size            = 13,
        Center          = true,
        Outline         = true,
        OutlineColor    = Color3.fromRGB(0, 0, 0),
    },
    Health = {
        HighColor       = Color3.fromRGB(0, 255, 0),
        LowColor        = Color3.fromRGB(255, 0, 0),
        Thickness       = 2,
        Outline         = true,
        ShowNumber      = false,
    },
    Distance = {
        Color           = Color3.fromRGB(255, 255, 255),
        Size            = 12,
        Outline         = true,
        Suffix          = " studs",
    },
    Tracer = {
        Color           = Color3.fromRGB(255, 255, 255),
        Thickness       = 1,
        Transparency    = 1,
        Origin          = "Bottom", -- "Top" | "Center" | "Bottom" | "Mouse"
    },
    Highlight = {
        FillColor          = Color3.fromRGB(255, 0, 0),
        OutlineColor       = Color3.fromRGB(255, 255, 255),
        FillTransparency   = 0.5,
        OutlineTransparency= 0,
        DepthMode          = Enum.HighlightDepthMode.AlwaysOnTop,
    },
}

-- ============== UTIL ==============
local function safeSet(obj, prop, val)
    pcall(function() obj[prop] = val end)
end

local function deepMerge(default, override)
    local result = {}
    for k, v in pairs(default) do
        if type(v) == "table" then
            result[k] = deepMerge(v, (override and type(override[k]) == "table") and override[k] or {})
        else
            result[k] = v
        end
    end
    if override then
        for k, v in pairs(override) do
            if result[k] == nil then result[k] = v end
        end
    end
    return result
end

local function getHighlightParent()
    if typeof(gethui) == "function" then
        local ok, hui = pcall(gethui)
        if ok and hui then return hui end
    end
    local ok, cg = pcall(function() return game:GetService("CoreGui") end)
    if ok and cg then return cg end
    return LocalPlayer:WaitForChild("PlayerGui")
end

local function newDrawing(class, props)
    local d = Drawing.new(class)
    for k, v in pairs(props or {}) do
        safeSet(d, k, v)
    end
    d.Visible = false
    return d
end

local function resolveValue(val, target)
    if type(val) == "function" then
        local ok, res = pcall(val, target)
        if ok then return res end
        return nil
    end
    return val
end

-- Get model bounding box projected to screen
local function getBoundingBox(model)
    if not model or not model.Parent then return nil end

    local cf, size
    if model:IsA("Model") then
        local ok
        ok, cf, size = pcall(function()
            local c, s = model:GetBoundingBox()
            return c, s
        end)
        if not ok then return nil end
    elseif model:IsA("BasePart") then
        cf, size = model.CFrame, model.Size
    else
        return nil
    end

    if not cf or not size then return nil end

    local corners = {}
    local hx, hy, hz = size.X / 2, size.Y / 2, size.Z / 2
    local offsets = {
        Vector3.new(-hx, -hy, -hz), Vector3.new( hx, -hy, -hz),
        Vector3.new(-hx,  hy, -hz), Vector3.new( hx,  hy, -hz),
        Vector3.new(-hx, -hy,  hz), Vector3.new( hx, -hy,  hz),
        Vector3.new(-hx,  hy,  hz), Vector3.new( hx,  hy,  hz),
    }
    for _, off in ipairs(offsets) do
        corners[#corners + 1] = (cf * CFrame.new(off)).Position
    end

    local minX, minY = math.huge, math.huge
    local maxX, maxY = -math.huge, -math.huge
    local anyOnScreen = false

    for _, worldPos in ipairs(corners) do
        local sp, onScreen = Camera:WorldToViewportPoint(worldPos)
        if sp.Z > 0 then
            if onScreen then anyOnScreen = true end
            if sp.X < minX then minX = sp.X end
            if sp.Y < minY then minY = sp.Y end
            if sp.X > maxX then maxX = sp.X end
            if sp.Y > maxY then maxY = sp.Y end
        end
    end

    if minX == math.huge then return nil end

    return {
        TopLeft     = Vector2.new(minX, minY),
        BottomRight = Vector2.new(maxX, maxY),
        Size        = Vector2.new(maxX - minX, maxY - minY),
        Center      = Vector2.new((minX + maxX) / 2, (minY + maxY) / 2),
        WorldCFrame = cf,
        OnScreen    = anyOnScreen,
    }
end

local function getCharacterFromTarget(target)
    if typeof(target) == "Instance" then
        if target:IsA("Player") then return target.Character end
        return target
    end
    return nil
end

local function getRootPart(model)
    if not model then return nil end
    if model:IsA("BasePart") then return model end
    return model:FindFirstChild("HumanoidRootPart") or model.PrimaryPart or model:FindFirstChildWhichIsA("BasePart")
end

local function isVisible(targetPart)
    if not targetPart then return false end
    local origin = Camera.CFrame.Position
    local dir = (targetPart.Position - origin)
    local params = RaycastParams.new()
    params.FilterType = Enum.RaycastFilterType.Exclude
    params.FilterDescendantsInstances = { LocalPlayer.Character or Instance.new("Model"), Camera }
    params.IgnoreWater = true

    local result = Workspace:Raycast(origin, dir, params)
    if not result then return true end
    return result.Instance:IsDescendantOf(targetPart.Parent)
end

-- ============== DRAWING CREATION ==============
local function createDrawings()
    return {
        Box       = newDrawing("Square",   { Thickness = 1, Filled = false }),
        BoxFill   = newDrawing("Square",   { Thickness = 1, Filled = true  }),
        BoxOutline= newDrawing("Square",   { Thickness = 3, Filled = false, Color = Color3.new(0,0,0) }),
        Name      = newDrawing("Text",     { Center = true, Outline = true, Size = 13 }),
        Distance  = newDrawing("Text",     { Center = true, Outline = true, Size = 12 }),
        Health    = newDrawing("Line",     { Thickness = 2 }),
        HealthBg  = newDrawing("Line",     { Thickness = 4, Color = Color3.new(0,0,0) }),
        HealthTxt = newDrawing("Text",     { Center = true, Outline = true, Size = 11 }),
        Tracer    = newDrawing("Line",     { Thickness = 1 }),
    }
end

local function destroyDrawings(d)
    for _, drawing in pairs(d) do
        pcall(function() drawing:Remove() end)
    end
end

local function hideDrawings(d)
    for _, drawing in pairs(d) do
        drawing.Visible = false
    end
end

-- ============== CORE UPDATE ==============
local function updateTracked(track)
    if not ESP.Settings.Enabled or track.Options.Enabled == false then
        hideDrawings(track.Drawings)
        if track.Highlight then track.Highlight.Enabled = false end
        return
    end

    local target = track.Target
    if not target or not target.Parent then
        ESP:Remove(target)
        return
    end

    -- Player-specific checks
    local character, humanoid
    if track.Type == "Player" then
        if ESP.Settings.HideOwnPlayer and target == LocalPlayer then
            hideDrawings(track.Drawings)
            if track.Highlight then track.Highlight.Enabled = false end
            return
        end
        character = target.Character
        if not character then hideDrawings(track.Drawings); return end
        humanoid = character:FindFirstChildOfClass("Humanoid")
        if not humanoid or humanoid.Health <= 0 then
            hideDrawings(track.Drawings)
            if track.Highlight then track.Highlight.Enabled = false end
            return
        end
        if ESP.Settings.TeamCheck and target.Team == LocalPlayer.Team then
            hideDrawings(track.Drawings)
            if track.Highlight then track.Highlight.Enabled = false end
            return
        end
    end

    -- Filter check
    if track.Options.Filter then
        local ok, allowed = pcall(track.Options.Filter, target)
        if not ok or not allowed then
            hideDrawings(track.Drawings)
            if track.Highlight then track.Highlight.Enabled = false end
            return
        end
    end

    local model = (track.Type == "Player") and character or target
    local rootPart = getRootPart(model)
    if not rootPart then hideDrawings(track.Drawings); return end

    -- Distance check
    local distance = (Camera.CFrame.Position - rootPart.Position).Magnitude
    local maxDist = track.Options.MaxDistance or ESP.Settings.MaxDistance
    if distance > maxDist then
        hideDrawings(track.Drawings)
        if track.Highlight then track.Highlight.Enabled = false end
        return
    end

    -- Wall check
    if ESP.Settings.WallCheck and not isVisible(rootPart) then
        hideDrawings(track.Drawings)
        if track.Highlight then track.Highlight.Enabled = false end
        return
    end

    -- Bounding box
    local bbox = getBoundingBox(model)
    if not bbox or not bbox.OnScreen then
        hideDrawings(track.Drawings)
        return
    end

    -- Resolve dynamic values
    local color = resolveValue(track.Options.Color, target) or ESP.Settings.Box.Color
    local name  = resolveValue(track.Options.Name,  target)
    if name == nil then
        if track.Type == "Player" then name = target.DisplayName or target.Name
        else name = target.Name end
    end

    local d = track.Drawings
    local opt = track.Options

    -- BOX
    if opt.Box ~= false then
        local cfg = ESP.Settings.Box
        if cfg.Outline then
            d.BoxOutline.Position = bbox.TopLeft
            d.BoxOutline.Size     = bbox.Size
            d.BoxOutline.Color    = cfg.OutlineColor
            d.BoxOutline.Visible  = true
        end
        if cfg.Filled then
            d.BoxFill.Position     = bbox.TopLeft
            d.BoxFill.Size         = bbox.Size
            d.BoxFill.Color        = color
            d.BoxFill.Transparency = 1 - cfg.FillTransparency
            d.BoxFill.Visible      = true
        end
        d.Box.Position     = bbox.TopLeft
        d.Box.Size         = bbox.Size
        d.Box.Color        = color
        d.Box.Thickness    = cfg.Thickness
        d.Box.Transparency = cfg.Transparency
        d.Box.Visible      = true
    else
        d.Box.Visible = false
        d.BoxFill.Visible = false
        d.BoxOutline.Visible = false
    end

    -- NAME TAG
    if opt.NameTag ~= false then
        local cfg = ESP.Settings.Name
        d.Name.Text     = tostring(name)
        d.Name.Position = Vector2.new(bbox.Center.X, bbox.TopLeft.Y - cfg.Size - 2)
        d.Name.Color    = color
        d.Name.Size     = cfg.Size
        d.Name.Center   = cfg.Center
        d.Name.Outline  = cfg.Outline
        d.Name.OutlineColor = cfg.OutlineColor
        d.Name.Visible  = true
    else
        d.Name.Visible = false
    end

    -- DISTANCE
    if opt.Distance ~= false then
        local cfg = ESP.Settings.Distance
        d.Distance.Text     = string.format("%d%s", math.floor(distance), cfg.Suffix)
        d.Distance.Position = Vector2.new(bbox.Center.X, bbox.BottomRight.Y + 2)
        d.Distance.Color    = cfg.Color
        d.Distance.Size     = cfg.Size
        d.Distance.Outline  = cfg.Outline
        d.Distance.Visible  = true
    else
        d.Distance.Visible = false
    end

    -- HEALTH BAR (players only)
    if opt.Health ~= false and track.Type == "Player" and humanoid then
        local cfg = ESP.Settings.Health
        local hp  = math.clamp(humanoid.Health / math.max(humanoid.MaxHealth, 1), 0, 1)
        local barX = bbox.TopLeft.X - 6
        local topY = bbox.TopLeft.Y
        local botY = bbox.BottomRight.Y
        local healthY = botY - (botY - topY) * hp

        if cfg.Outline then
            d.HealthBg.From    = Vector2.new(barX, topY - 1)
            d.HealthBg.To      = Vector2.new(barX, botY + 1)
            d.HealthBg.Visible = true
        end

        d.Health.From      = Vector2.new(barX, healthY)
        d.Health.To        = Vector2.new(barX, botY)
        d.Health.Color     = cfg.LowColor:Lerp(cfg.HighColor, hp)
        d.Health.Thickness = cfg.Thickness
        d.Health.Visible   = true

        if cfg.ShowNumber then
            d.HealthTxt.Text     = tostring(math.floor(humanoid.Health))
            d.HealthTxt.Position = Vector2.new(barX - 4, healthY - 6)
            d.HealthTxt.Color    = d.Health.Color
            d.HealthTxt.Visible  = true
        end
    else
        d.Health.Visible   = false
        d.HealthBg.Visible = false
        d.HealthTxt.Visible= false
    end

    -- TRACER
    if opt.Tracer == true then
        local cfg = ESP.Settings.Tracer
        local viewport = Camera.ViewportSize
        local origin
        if cfg.Origin == "Top" then
            origin = Vector2.new(viewport.X / 2, 0)
        elseif cfg.Origin == "Center" then
            origin = viewport / 2
        elseif cfg.Origin == "Mouse" then
            local mp = UserInputSvc:GetMouseLocation()
            origin = Vector2.new(mp.X, mp.Y)
        else
            origin = Vector2.new(viewport.X / 2, viewport.Y)
        end
        d.Tracer.From         = origin
        d.Tracer.To           = Vector2.new(bbox.Center.X, bbox.BottomRight.Y)
        d.Tracer.Color        = color
        d.Tracer.Thickness    = cfg.Thickness
        d.Tracer.Transparency = cfg.Transparency
        d.Tracer.Visible      = true
    else
        d.Tracer.Visible = false
    end

    -- HIGHLIGHT (chams)
    if opt.Highlight and track.Highlight then
        local cfg = ESP.Settings.Highlight
        track.Highlight.Adornee            = model
        track.Highlight.FillColor          = color
        track.Highlight.OutlineColor       = cfg.OutlineColor
        track.Highlight.FillTransparency   = cfg.FillTransparency
        track.Highlight.OutlineTransparency= cfg.OutlineTransparency
        track.Highlight.DepthMode          = cfg.DepthMode
        track.Highlight.Enabled            = true
    elseif track.Highlight then
        track.Highlight.Enabled = false
    end
end

-- ============== PUBLIC API ==============
function ESP:Init()
    if self._Initialized then return end
    self._Initialized = true

    self._RenderConn = RunService.RenderStepped:Connect(function()
        for target, track in pairs(self._Tracked) do
            local ok, err = pcall(updateTracked, track)
            if not ok then
                -- swallow errors silently per-target
            end
        end
    end)

    -- Auto-handle player join/leave for category-applied players
    self._Connections.PlayerAdded = Players.PlayerAdded:Connect(function(plr)
        for catName, _ in pairs(self._CategoryAll) do
            self:AddPlayer(plr, self._Categories[catName])
        end
    end)
    self._Connections.PlayerRemoving = Players.PlayerRemoving:Connect(function(plr)
        self:Remove(plr)
    end)
end

function ESP:Toggle(state)
    self.Settings.Enabled = state and true or false
end

function ESP:Configure(overrides)
    if type(overrides) ~= "table" then return end
    self.Settings = deepMerge(self.Settings, overrides)
end

function ESP:AddPlayer(player, options)
    if not self._Initialized then self:Init() end
    if not player or not player:IsA("Player") then return end
    if self._Tracked[player] then self:Remove(player) end

    options = options or {}

    local track = {
        Type      = "Player",
        Target    = player,
        Options   = options,
        Drawings  = createDrawings(),
        Highlight = nil,
        Connections = {},
    }

    if options.Highlight then
        local hl = Instance.new("Highlight")
        hl.Name    = "ESP_" .. tostring(math.random(1, 1e9))
        hl.Enabled = false
        hl.Parent  = getHighlightParent()
        track.Highlight = hl
    end

    self._Tracked[player] = track
    return track
end

function ESP:AddObject(instance, options)
    if not self._Initialized then self:Init() end
    if not instance or typeof(instance) ~= "Instance" then return end
    if self._Tracked[instance] then self:Remove(instance) end

    options = options or {}

    local track = {
        Type      = "Object",
        Target    = instance,
        Options   = options,
        Drawings  = createDrawings(),
        Highlight = nil,
        Connections = {},
    }

    if options.Highlight then
        local hl = Instance.new("Highlight")
        hl.Name    = "ESP_" .. tostring(math.random(1, 1e9))
        hl.Enabled = false
        hl.Parent  = getHighlightParent()
        track.Highlight = hl
    end

    -- Auto-cleanup when object is destroyed
    track.Connections.Destroying = instance.Destroying:Connect(function()
        self:Remove(instance)
    end)

    self._Tracked[instance] = track
    return track
end

function ESP:Remove(target)
    local track = self._Tracked[target]
    if not track then return end
    destroyDrawings(track.Drawings)
    if track.Highlight then pcall(function() track.Highlight:Destroy() end) end
    for _, conn in pairs(track.Connections) do
        pcall(function() conn:Disconnect() end)
    end
    self._Tracked[target] = nil
end

function ESP:RegisterCategory(name, definition)
    self._Categories[name] = definition
end

function ESP:AddPlayersByCategory(name, applyToFuture)
    local def = self._Categories[name]
    if not def then warn("[ESP] Category not registered: " .. tostring(name)) return end
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer then
            self:AddPlayer(plr, def)
        end
    end
    if applyToFuture ~= false then
        self._CategoryAll[name] = true
    end
end

function ESP:Destroy()
    if self._RenderConn then self._RenderConn:Disconnect() end
    for _, conn in pairs(self._Connections) do
        pcall(function() conn:Disconnect() end)
    end
    for target, _ in pairs(self._Tracked) do
        self:Remove(target)
    end
    self._Initialized = false
end

return ESP
